:: RapidAutomate Node Configuration
:: Edit these values before first run

:: Cloud API connection
set CENTRAL_API_URL=https://rapidranking-api.vercel.app
set CENTRAL_API_PREFIX=/api/v1
set CENTRAL_API_EMAIL=jenn@rapidrankings.io
set CENTRAL_API_PASSWORD=RapidRank2026

:: Service ports (change if conflicts)
set ENGINE_PORT=3500
set CONTENT_PORT=3001

:: API key for local service communication
set API_KEY=desktop-api-key-1234567890

:: Browser mode: true=invisible, false=show Chrome windows
set HEADLESS=true

:: Encryption key for antidetect engine (32 hex chars)
set ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
